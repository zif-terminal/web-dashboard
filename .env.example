# Backend URLs (server-side only, used by next.config.ts rewrites)
# For local development:
#   HASURA_URL=http://localhost:8080
#   AUTH_URL=http://localhost:8081
# For remote (default if not set):
#   HASURA_URL=http://167.99.145.4
#   AUTH_URL=http://167.99.145.4
HASURA_URL=http://167.99.145.4
AUTH_URL=http://167.99.145.4

# Frontend endpoints (use the Next.js proxy - no need to change these)
NEXT_PUBLIC_GRAPHQL_ENDPOINT=/api/graphql
NEXT_PUBLIC_AUTH_ENDPOINT=/api/auth
NEXT_PUBLIC_USE_MOCK_API=false
