#!/bin/bash
#
# Pre-push hook: blocks direct pushes to main, runs lint and build

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Check if pushing to main
while read local_ref local_sha remote_ref remote_sha; do
    if [[ "$remote_ref" == "refs/heads/main" ]]; then
        echo -e "${RED}ERROR: Direct pushes to main are not allowed.${NC}"
        echo ""
        echo "Create a pull request instead:"
        echo "  git push origin <branch-name>"
        exit 1
    fi
done

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo -e "${YELLOW}Pre-push: Running lint and build...${NC}"

npm run lint
npm run build

echo -e "${GREEN}All checks passed!${NC}"
